    "react-dom": "^18.2.0",
    "react-helmet": "^6.1.0",
    "react-router-dom": "^6.20.1"
  },
  "optionalDependencies": {
    "framer-motion": "^10.16.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^22.13.10",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
